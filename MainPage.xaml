<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:WorkoutApp.ViewModels"
             x:Class="WorkoutApp.MainPage"
             Title="Workout Tracker"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,20">
            <Label Text="Cześć!" FontSize="26" FontAttributes="Bold" TextColor="#2F3640"/>
            <Label Text="Twoja historia treningów (kliknij trening, aby dodać ćwiczenia):" FontSize="14" TextColor="#718093"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding Workouts}" EmptyView="Brak zapisanych treningów. Wpisz swój pierwszy trening poniżej!">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="0" BackgroundColor="White" Margin="0,0,0,12" Padding="16">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="5" Opacity="0.05"/>
                        </Border.Shadow>

                        <Grid ColumnDefinitions="*, Auto, Auto">

                            <VerticalStackLayout Grid.Column="0" Spacing="4">
                                <VerticalStackLayout.GestureRecognizers>
                                    <TapGestureRecognizer Command="{Binding BindingContext.GoToDetailsCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                                </VerticalStackLayout.GestureRecognizers>
                                <Label Text="{Binding Name}" FontSize="18" FontAttributes="Bold" TextColor="#2F3640"/>
                                <Label Text="{Binding Date, StringFormat='{0:dd.MM.yyyy, HH:mm}'}" FontSize="13" TextColor="#718093"/>
                            </VerticalStackLayout>

                            <Label Grid.Column="1" Text="{Binding Duration, StringFormat='{0:hh\\:mm}'}" FontSize="16" FontAttributes="Bold" TextColor="#00A8FF" VerticalOptions="Center" Margin="0,0,15,0"/>

                            <Button Grid.Column="2" Text="❌" BackgroundColor="Transparent" TextColor="Red" FontSize="14" WidthRequest="40" HeightRequest="40" Padding="0" VerticalOptions="Center"
                                    Command="{Binding BindingContext.DeleteWorkoutCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2" BackgroundColor="White" StrokeShape="RoundRectangle 15" Padding="15" Margin="0,10,0,0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="10" Opacity="0.05"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="10">
                <Entry Text="{Binding NewWorkoutName}" TextColor="Black" Placeholder="Nazwa nowego treningu (np. Push, Nogi)" BackgroundColor="#F5F6FA" ClearButtonVisibility="WhileEditing"/>
                <Entry Text="{Binding NewWorkoutDuration}" TextColor="Black" Placeholder="Czas trwania (w minutach)" Keyboard="Numeric" BackgroundColor="#F5F6FA" ClearButtonVisibility="WhileEditing"/>
                <Button Text="Zapisz trening" Command="{Binding AddWorkoutCommand}" BackgroundColor="#20bf6b" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="45" Margin="0,5,0,0"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>