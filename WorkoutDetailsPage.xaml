<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:WorkoutApp.ViewModels"
             x:Class="WorkoutApp.WorkoutDetailsPage"
             Title="Szczegóły Treningu"
             BackgroundColor="#F5F6FA">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">

        <VerticalStackLayout Grid.Row="0" Spacing="5" Margin="0,0,0,20">
            <Label Text="{Binding SelectedWorkout.Name}" FontSize="24" FontAttributes="Bold" TextColor="#2F3640"/>
            <Label Text="{Binding SelectedWorkout.Date, StringFormat='{0:dd.MM.yyyy, HH:mm}'}" FontSize="14" TextColor="#718093"/>
        </VerticalStackLayout>

        <CollectionView Grid.Row="1" ItemsSource="{Binding DisplaySets}" EmptyView="Brak serii w tym treningu. Dodaj pierwszą poniżej!">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="White" Margin="0,0,0,8" Padding="12">
                        <Grid ColumnDefinitions="*, Auto">
                            <Label Grid.Column="0" Text="{Binding DisplayText}" FontSize="16" TextColor="#2F3640" FontAttributes="Bold" VerticalOptions="Center"/>
                            <Button Grid.Column="1" Text="❌" BackgroundColor="Transparent" TextColor="Red" FontSize="14" WidthRequest="40" HeightRequest="40" Padding="0" VerticalOptions="Center"
                                    Command="{Binding BindingContext.DeleteSetCommand, Source={RelativeSource AncestorType={x:Type ContentPage}}}" CommandParameter="{Binding .}"/>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Border Grid.Row="2" BackgroundColor="White" StrokeShape="RoundRectangle 15" Padding="15" Margin="0,10,0,0">
            <VerticalStackLayout Spacing="10">

                <Label Text="Nie ma Twojego ćwiczenia? Dodaj je do listy:" FontAttributes="Bold" FontSize="13" TextColor="#718093"/>
                <Grid ColumnDefinitions="*, Auto">
                    <Entry Grid.Column="0" Text="{Binding NewExerciseName}" TextColor="Black" Placeholder="np. Martwy ciąg" BackgroundColor="#F5F6FA"/>
                    <Button Grid.Column="1" Text="➕" Command="{Binding AddExerciseCommand}" BackgroundColor="#20bf6b" TextColor="White" FontAttributes="Bold" WidthRequest="45" HeightRequest="40" CornerRadius="8" Margin="5,0,0,0"/>
                </Grid>

                <BoxView HeightRequest="1" Color="#E1E4E8" Margin="0,5"/>

                <Label Text="Zapisz serię dla wybranego ćwiczenia:" FontAttributes="Bold" TextColor="#2F3640"/>
                <Picker Title="Wybierz ćwiczenie z listy" TextColor="Black" ItemsSource="{Binding Exercises}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedExercise}" BackgroundColor="#F5F6FA"/>

                <Grid ColumnDefinitions="*, *">
                    <Entry Grid.Column="0" Text="{Binding Reps}" TextColor="Black" Placeholder="Powtórzenia" Keyboard="Numeric" BackgroundColor="#F5F6FA" Margin="0,0,5,0"/>
                    <Entry Grid.Column="1" Text="{Binding Weight}" TextColor="Black" Placeholder="Ciężar (kg)" Keyboard="Numeric" BackgroundColor="#F5F6FA" Margin="5,0,0,0"/>
                </Grid>

                <Button Text="Dodaj serię" Command="{Binding AddSetCommand}" BackgroundColor="#00A8FF" TextColor="White" FontAttributes="Bold" CornerRadius="10" HeightRequest="45"/>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentPage>